{
  "name": "@conaonda/ol-cog-layers",
  "version": "0.3.1",
  "description": "OpenLayers COG rendering layers — WebGL tile + Canvas image pipelines",
  "type": "module",
  "main": "dist/ol-cog-layers.cjs",
  "module": "dist/ol-cog-layers.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/ol-cog-layers.js",
      "require": "./dist/ol-cog-layers.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "types"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "lint": "eslint src",
    "format": "prettier --write src",
    "examples": "vite --config vite.config.examples.js",
    "examples:build": "vite build --config vite.config.examples.js"
  },
  "peerDependencies": {
    "ol": ">=10.0.0"
  },
  "dependencies": {
    "geotiff": "^2.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "ol": "^10.0.0",
    "playwright": "^1.58.2",
    "prettier": "^3.0.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "author": "conaonda",
  "repository": {
    "type": "git",
    "url": "https://github.com/conaonda/ol-cog-layers.git"
  },
  "bugs": {
    "url": "https://github.com/conaonda/ol-cog-layers/issues"
  },
  "homepage": "https://github.com/conaonda/ol-cog-layers#readme",
  "keywords": [
    "openlayers",
    "cog",
    "geotiff",
    "webgl",
    "gis"
  ]
}
